rules_version = '2';
// 12s — Firestore security rules
// Enforces: only the seated players (2-4) can touch their game, only the
// active player can make a move, a waiting game is joinable by code (seats
// fill in order), and each player's hand is readable/writable only by them.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    match /games/{gameId} {
      // GET a single game: members always; a 'waiting' game is gettable by
      // anyone signed in who has the code (so they can join it).
      allow get: if isSignedIn() && (
        resource.data.status == 'waiting'
        || request.auth.uid in resource.data.playerUids
      );
      // LIST (queries): only your own games. This satisfies the
      // playerUids array-contains query used to find your active game, and
      // prevents listing other people's or all 'waiting' games.
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.playerUids;
      // CREATE a new game: you are player 0, the only member, status 'waiting',
      // and the table has 2-4 seats total.
      allow create: if isSignedIn()
        && request.resource.data.players[0].uid == request.auth.uid
        && request.resource.data.playerUids.size() == 1
        && request.auth.uid in request.resource.data.playerUids
        && request.resource.data.status == 'waiting'
        && request.resource.data.players.size() >= 2
        && request.resource.data.players.size() <= 4;
      // UPDATE: either (a) joining a waiting game into the next open seat
      //         (seats fill in order: p0 is the creator, then p1, p2, p3 as
      //         people join — status only flips to 'active' once every seat
      //         is filled), or (b) a move written by the current active player.
      allow update: if isSignedIn() && (
        joiningNextSeat()
        ||
        (
          request.auth.uid == resource.data.players[resource.data.currentTurnIndex].uid
        )
      );
      // No client-side deletes.
      allow delete: if false;

      // The next open seat is always right after the currently-bound ones,
      // since playerUids only ever holds bound uids, in seat order.
      function joiningNextSeat() {
        let slot = resource.data.playerUids.size();
        return resource.data.status == 'waiting'
          && slot < resource.data.players.size()
          && resource.data.players[slot].uid == null
          && request.resource.data.players[slot].uid == request.auth.uid
          && request.resource.data.players[0].uid == resource.data.players[0].uid
          && request.resource.data.players.size() == resource.data.players.size()
          && request.resource.data.playerUids.size() == slot + 1
          && request.resource.data.playerUids[slot] == request.auth.uid
          && otherSeatsUnchanged(slot)
          && ((request.resource.data.playerUids.size() == request.resource.data.players.size())
              == (request.resource.data.status == 'active'));
      }

      // Every seat except the one being claimed must keep the same uid it had
      // before this write (guards against a join write smuggling in changes
      // to anyone else's seat). Guarded by size() so it never indexes past
      // however many seats this particular game actually has (2, 3, or 4).
      function otherSeatsUnchanged(slot) {
        return (slot == 1 || resource.data.players.size() < 2 || resource.data.players[1].uid == request.resource.data.players[1].uid)
            && (slot == 2 || resource.data.players.size() < 3 || resource.data.players[2].uid == request.resource.data.players[2].uid)
            && (slot == 3 || resource.data.players.size() < 4 || resource.data.players[3].uid == request.resource.data.players[3].uid);
      }

      // ---------- private hands ----------
      match /hands/{handId} {
        function gameData() {
          return get(/databases/$(database)/documents/games/$(gameId)).data;
        }
        // Map the hand document id ('p0'..'p3') to the uid bound to that slot.
        function ownerUid() {
          return handId == 'p0' ? gameData().players[0].uid
               : handId == 'p1' ? gameData().players[1].uid
               : handId == 'p2' ? gameData().players[2].uid
               : handId == 'p3' ? gameData().players[3].uid
               : '';
        }
        allow read, write: if isSignedIn()
          && request.auth.uid == ownerUid();
      }

      // ---------- chat ----------
      match /chat/{msgId} {
        function isPlayer() {
          return request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerUids;
        }
        // Both players can read all messages.
        allow read: if isSignedIn() && isPlayer();
        // Either player can post, but only as themselves.
        allow create: if isSignedIn()
          && isPlayer()
          && request.resource.data.uid == request.auth.uid;
        // No editing or deleting messages.
        allow update, delete: if false;
      }
    }
  }
}
